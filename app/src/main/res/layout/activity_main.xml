<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#3F51B5"
        app:tabTextColor="#CCFFFFFF"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#FFFFFF"
        app:tabIndicatorHeight="5dp"
        app:tabTextAppearance="@android:style/TextAppearance.Large"> <com.google.android.material.tabs.TabItem android:text="Milk"  android:layout_height="match_parent" android:layout_width="match_parent"/>
        <com.google.android.material.tabs.TabItem android:text="Diaper"  android:layout_height="match_parent" android:layout_width="match_parent"/>

    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</LinearLayout>