<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvDiaperTimeSince"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last change: --"
        android:textSize="22sp"
        android:textColor="?android:attr/textColorPrimary"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/tvDiaperStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total changes today: 0"
        android:textSize="22sp"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnLogDiaper"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:backgroundTint="#3F51B5"
        android:text="Add diaper change"
        android:textSize="22sp"
        android:textColor="#FFFFFF" />

    <ListView
        android:id="@+id/lvDiaperHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btnClearDiapers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Clear History"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />
</LinearLayout>